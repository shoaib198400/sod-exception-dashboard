def render_header(subtitle: str = "") -> None:
    """Render the top HPCL branded header banner."""
    now = datetime.now().strftime("%d %b %Y  |  %I:%M %p")
    pipe = f"&nbsp;&nbsp;|&nbsp;&nbsp;{subtitle}" if subtitle else ""
    st.markdown(f"""
    <div class="dash-header">
        <div>
            <p class="dash-header-title">⛽&nbsp; SOD Exception Dashboard</p>
            <p class="dash-header-sub">
                Supply &amp; Operations Division — Exception Monitoring System{pipe}
            </p>
        </div>
        <div class="dash-header-meta">
            <div class="company">HPCL</div>
            <div>Hindustan Petroleum Corporation Limited</div>
            <div style="margin-top:5px;">{now}</div>
        </div>
    </div>
    """, unsafe_allow_html=True)


def kpi_card(
    label      : str,
    value      : int,
    detail     : str  = "",
    icon       : str  = "📦",
    color_class: str  = "",
    key        : str  = None,
) -> bool:
    """
    Render a KPI tile card.

    Returns True if the "View Details" button beneath the card was clicked.
    The button is hidden under the card styling to simulate a clickable tile.
    """
    formatted = f"{value:,}" if isinstance(value, (int, float)) else str(value)
    detail_html = f"<div class='kpi-detail'>{detail}</div>" if detail else ""
    st.markdown(f"""
    <div class="kpi-wrap {color_class}">
        <span class="kpi-icon">{icon}</span>
        <div class="kpi-label">{label}</div>
        <div class="kpi-value">{formatted}</div>
        {detail_html}
    </div>
    """, unsafe_allow_html=True)
    return st.button("📋 View Details →", key=key or f"btn_{label}", use_container_width=True)


def export_to_excel(df_dict: dict[str, pd.DataFrame]) -> bytes:
    """Serialise a dict of {sheet_name: DataFrame} to Excel bytes for download."""
    buf = BytesIO()
    with pd.ExcelWriter(buf, engine="openpyxl") as writer:
        for sheet, df in df_dict.items():
            if df is not None and not df.empty:
                df.to_excel(writer, index=False, sheet_name=sheet[:31])
    buf.seek(0)
    return buf.getvalue()


# ─────────────────────────────────────────────────────────────────────────────
# SIDEBAR
# ─────────────────────────────────────────────────────────────────────────────

def render_sidebar(df_plant: pd.DataFrame) -> tuple:
    """
    Render the left navigation sidebar.

    Returns:
        (selected_zones, selected_plants, uploaded_dc_file)
    """
    with st.sidebar:
        # ── Logo Area ────────────────────────────────────────────────────────
        st.markdown("""
        <div style="text-align:center;padding:14px 0 6px;">
            <div style="font-size:2.6rem;">⛽</div>
            <div style="font-size:1.1rem;font-weight:700;letter-spacing:.06em;color:#FFFFFF;">HPCL</div>
            <div style="font-size:0.68rem;opacity:.7;color:#AACCFF;">Exception Monitoring</div>
        </div>
        <hr/>
        """, unsafe_allow_html=True)

        # ── Navigation Filters ───────────────────────────────────────────────
        st.markdown('<p class="sb-nav-lbl">📍 Navigation Filters</p>', unsafe_allow_html=True)

        all_zones = sorted(df_plant["Zone Name"].dropna().unique().tolist())
        selected_zones = st.multiselect(
            "Zone",
            options     = all_zones,
            default     = [],
            placeholder = "All Zones",
            help        = "Select one or more zones to filter the dashboard",
        )

        # Plant list cascades from zone selection
        if selected_zones:
            avail_plants = (
                df_plant[df_plant["Zone Name"].isin(selected_zones)]
                ["Plant Name"].dropna().unique().tolist()
            )
        else:
            avail_plants = df_plant["Plant Name"].dropna().unique().tolist()

        selected_plants = st.multiselect(
            "Plant / Location",
            options     = sorted(avail_plants),
            default     = [],
            placeholder = "All Plants",
            help        = "Select one or more plants",
        )

        st.markdown("<hr/>", unsafe_allow_html=True)

        # ── File Upload ──────────────────────────────────────────────────────
        st.markdown('<p class="sb-nav-lbl">📂 Data Upload</p>', unsafe_allow_html=True)
        uploaded_dc = st.file_uploader(
            "Pending DC File  (.xls / .xlsx)",
            type = ["xls", "xlsx"],
            help = "Upload PENDING_DC_SOD file to override the default source",
            key  = "uploader_pending_dc",
        )

        st.markdown("<hr/>", unsafe_allow_html=True)

        # ── System Info ──────────────────────────────────────────────────────
        st.markdown('<p class="sb-nav-lbl">ℹ️ System Info</p>', unsafe_allow_html=True)
        plant_cnt = len(df_plant)
        zone_cnt  = df_plant["Zone Name"].nunique()
        st.markdown(f"""
        <div style="font-size:0.78rem;line-height:2;opacity:.88;">
            🏭 &nbsp;Active Plants : <b>{plant_cnt}</b><br/>
            🗺️ &nbsp;Zones         : <b>{zone_cnt}</b><br/>
            📅 &nbsp;Date          : <b>{datetime.now().strftime('%d %b %Y')}</b>
        </div>
        """, unsafe_allow_html=True)

        # ── Cache Refresh ────────────────────────────────────────────────────
        st.markdown("<hr/>", unsafe_allow_html=True)
        if st.button("🔄 Refresh Data", use_container_width=True, key="btn_refresh"):
            st.cache_data.clear()
            st.rerun()

    return selected_zones, selected_plants, uploaded_dc


# ─────────────────────────────────────────────────────────────────────────────
# PAGE: MAIN DASHBOARD
# ─────────────────────────────────────────────────────────────────────────────

def render_dashboard(
    pending_dc_result : dict,
    zone_filter       : list,
    plant_filter      : list,
) -> None:
    """
    Main dashboard page.

    Displays:
      • Active filter badges
      • KPI tiles (Pending DC's + placeholder tiles for future parameters)
      • Zone-wise bar chart
      • Plant-wise summary table
    """
    render_header()

    # ── Active filter badges ─────────────────────────────────────────────────
    if zone_filter or plant_filter:
        badges = "".join(
            [f'<span class="fbadge">📍 {z}</span>' for z in zone_filter]
            + [f'<span class="fbadge">🏭 {p}</span>' for p in plant_filter]
        )
        st.markdown(
            f'<div style="margin-bottom:10px;font-size:.8rem;">Active Filters:&nbsp;{badges}</div>',
            unsafe_allow_html=True,
        )

    # ── ROW 1 — KPI Tiles ────────────────────────────────────────────────────
    st.markdown('<div class="sec-title">📊 Exception Parameters — Live Summary</div>',
                unsafe_allow_html=True)

    col1, col2, col3, col4 = st.columns(4, gap="small")

    with col1:
        total_dc   = pending_dc_result.get("total_count", 0)
        s_df       = pending_dc_result.get("summary_df", pd.DataFrame())
        z_df       = pending_dc_result.get("zone_summary", pd.DataFrame())
        detail_str = f"{len(z_df)} zones  |  {len(s_df)} plants affected"
        color_cls  = "c-danger" if total_dc > 50 else ("c-warning" if total_dc > 20 else "")
        clicked_dc = kpi_card(
            label       = "Pending DC's",
            value       = total_dc,
            detail      = detail_str,
            icon        = "🚚",
            color_class = color_cls,
            key         = "tile_pending_dc",
        )
        if clicked_dc:
            st.session_state["page"] = "pending_dc_details"
            st.rerun()

    with col2:
        kpi_card("Open Deliveries",    0, "Coming Soon", "📦", "c-muted", "tile_open_del")

    with col3:
        kpi_card("Pending Invoices",   0, "Coming Soon", "🧾", "c-muted", "tile_pend_inv")

    with col4:
        kpi_card("Open Sales Orders",  0, "Coming Soon", "📋", "c-muted", "tile_open_so")

    st.markdown("<div style='height:14px'></div>", unsafe_allow_html=True)

    # ── ROW 2 — KPI Tiles ────────────────────────────────────────────────────
    col5, col6, col7, col8 = st.columns(4, gap="small")

    with col5:
        kpi_card("Open Intransit",         0, "Coming Soon", "🚛",  "c-muted",   "tile_intrans")
    with col6:
        kpi_card("Open Shortages (Sales)", 0, "Coming Soon", "⚠️",  "c-muted", "tile_sh_sal")
    with col7:
        kpi_card("Open Shortages (STO)",   0, "Coming Soon", "⚠️",  "c-muted", "tile_sh_sto")
    with col8:
        kpi_card("Tank Reco",              0, "Coming Soon", "🛢️",  "c-muted",   "tile_tank")

    st.markdown("<div style='height:10px'></div>", unsafe_allow_html=True)

    # ── Zone Chart ────────────────────────────────────────────────────────────
    zone_summary = pending_dc_result.get("zone_summary", pd.DataFrame())
    if not zone_summary.empty:
        st.markdown('<div class="sec-title">📍 Zone-wise Pending DC\'s</div>',
                    unsafe_allow_html=True)
        _render_zone_bar(zone_summary)

    # ── Summary Table ─────────────────────────────────────────────────────────
    summary_df = pending_dc_result.get("summary_df", pd.DataFrame())
    if not summary_df.empty:
        st.markdown('<div class="sec-title">🏭 Plant-wise Summary</div>',
                    unsafe_allow_html=True)
        with st.expander("View Plant-wise Table", expanded=True):
            st.dataframe(
                summary_df.reset_index(drop=True),
                use_container_width = True,
                hide_index          = True,
                column_config       = {
                    "Zone Name"       : st.column_config.TextColumn("Zone",       width="medium"),
                    "Plant Name"      : st.column_config.TextColumn("Plant",      width="large"),
                    "Pending DC Count": st.column_config.NumberColumn("Pending DCs", format="%d"),
                },
            )

    # ── Unmatched plant warning ───────────────────────────────────────────────
    unmatched = pending_dc_result.get("unmatched", [])
    if unmatched:
        with st.expander(f"⚠️ {len(unmatched)} Plant Code(s) not found in PlantMaster", expanded=False):
            st.warning(
                "The following Sending Plant codes from the DC file could not be "
                "mapped to PlantMaster. Update PlantMaster or check the data.\n\n"
                + "  |  ".join(str(c) for c in unmatched)
            )


def _render_zone_bar(zone_summary: pd.DataFrame) -> None:
    """Render a Plotly bar chart for zone-wise Pending DC counts."""
    fig = px.bar(
        zone_summary,
        x                    = "Zone Name",
        y                    = "Pending DC Count",
        color                = "Pending DC Count",
        color_continuous_scale = [[0, "#B8D4FF"], [1, C["primary"]]],
        text                 = "Pending DC Count",
        labels               = {"Pending DC Count": "Pending DCs", "Zone Name": "Zone"},
    )
    fig.update_traces(textposition="outside", textfont_size=11)
    fig.update_layout(
        plot_bgcolor        = "white",
        paper_bgcolor       = "white",
        font                = dict(family="Segoe UI", size=12),
        margin              = dict(l=10, r=10, t=10, b=90),
        coloraxis_showscale = False,
        xaxis               = dict(tickangle=-30),
        height              = 310,
    )
    st.plotly_chart(fig, use_container_width=True, config={"displayModeBar": False})


# ─────────────────────────────────────────────────────────────────────────────
# PAGE: PENDING DC DETAILS (DRILL-DOWN)
# ─────────────────────────────────────────────────────────────────────────────

def render_pending_dc_details(
    pending_dc_result : dict,
    zone_filter       : list,
    plant_filter      : list,
) -> None:
    """
    Drill-down detail page for the Pending DC's exception parameter.

    Displays:
      • Back to Dashboard button
      • Summary metric row (total DCs, zones, plants, quantity)
      • Zone-level pivot table
      • Plant-level pivot table organised in tabs (one tab per zone)
      • Raw shipment-level detail (expandable)
      • Excel download button
    """
    render_header(subtitle="🚚 Pending DC's — Drill Down")

    # ── Navigation ────────────────────────────────────────────────────────────
    back_col, _ = st.columns([1, 6])
    with back_col:
        if st.button("◀  Back to Dashboard", key="btn_back"):
            st.session_state["page"] = "dashboard"
            st.rerun()

    st.markdown("""
    <div class="detail-hdr">
        <h3>🚚 Pending DC's — Detailed Exception View</h3>
        <p>Zone-wise and Plant-wise breakdown of all Pending Delivery Challans
        (counted as unique Shipment numbers per Sending Plant)</p>
    </div>
    """, unsafe_allow_html=True)

    summary_df   = pending_dc_result.get("summary_df",   pd.DataFrame())
    zone_summary = pending_dc_result.get("zone_summary",  pd.DataFrame())
    detail_df    = pending_dc_result.get("detail_df",    pd.DataFrame())
    total_count  = pending_dc_result.get("total_count",  0)

    if summary_df.empty:
        st.info("ℹ️ No data available for the current filter selection.")
        return

    # ── Top Metrics Row ───────────────────────────────────────────────────────
    total_zones  = int(summary_df["Zone Name"].nunique())
    total_plants = int(summary_df["Plant Name"].nunique())

    m1, m2, m3, m4 = st.columns(4)
    m1.metric("Pending DC's (Total)",  f"{total_count:,}",  help="Count of unique shipments")
    m2.metric("Zones Affected",        f"{total_zones}")
    m3.metric("Plants Affected",       f"{total_plants}")

    # Optional: total quantity from detail rows (de-duped at shipment level)
    if not detail_df.empty and "QUANTITY" in detail_df.columns:
        try:
            deduped_qty = (
                detail_df
                .drop_duplicates(subset=["SENDING PLANT", "SHIPMENT"])
                ["QUANTITY"]
                .sum()
            )
            m4.metric("Total Qty (L)", f"{deduped_qty:,.0f}")
        except Exception:
            m4.metric("Total Qty (L)", "N/A")

    st.markdown("---")

    # ── Zone-Level Table ──────────────────────────────────────────────────────
    st.markdown('<div class="sec-title">📍 Zone-wise Summary</div>', unsafe_allow_html=True)

    if not zone_summary.empty:
        z_display = zone_summary.rename(columns={"Plants": "Plants Affected"})
        st.dataframe(
            z_display,
            use_container_width = True,
            hide_index          = True,
            column_config       = {
                "Zone Name"      : st.column_config.TextColumn("Zone",            width="medium"),
                "Plants Affected": st.column_config.NumberColumn("Plants Affected", format="%d"),
                "Pending DC Count": st.column_config.NumberColumn("Pending DC's",   format="%d"),
            },
        )

    st.markdown('<div class="sec-title" style="margin-top:20px;">🏭 Plant-wise Drill Down (Zone → Plant → Count)</div>',
                unsafe_allow_html=True)

    # ── Zone Tabs (max 10; fall back to selectbox for more) ──────────────────
    all_zones_in_data = sorted(summary_df["Zone Name"].dropna().unique().tolist())

    if len(all_zones_in_data) <= 10:
        tabs = st.tabs(all_zones_in_data)
        for tab, zone in zip(tabs, all_zones_in_data):
            with tab:
                z_df       = summary_df[summary_df["Zone Name"] == zone][
                    ["Plant Name", "Pending DC Count"]
                ].reset_index(drop=True)
                zone_total = int(z_df["Pending DC Count"].sum())
                st.caption(f"**{zone}** — {len(z_df)} plant(s)  |  {zone_total} Pending DC's")
                st.dataframe(
                    z_df,
                    use_container_width = True,
                    hide_index          = True,
                    column_config       = {
                        "Plant Name"      : st.column_config.TextColumn("Plant",       width="large"),
                        "Pending DC Count": st.column_config.NumberColumn("Pending DC's", format="%d"),
                    },
                )
    else:
        sel_zone = st.selectbox(
            "Select Zone to Expand",
            ["— All Zones —"] + all_zones_in_data,
            key="sel_zone_detail",
        )
        if sel_zone == "— All Zones —":
            disp_df = summary_df.reset_index(drop=True)
        else:
            disp_df = summary_df[summary_df["Zone Name"] == sel_zone][
                ["Plant Name", "Pending DC Count"]
            ].reset_index(drop=True)

        st.dataframe(
            disp_df,
            use_container_width = True,
            hide_index          = True,
            column_config       = {
                "Zone Name"       : st.column_config.TextColumn("Zone",       width="medium"),
                "Plant Name"      : st.column_config.TextColumn("Plant",      width="large"),
                "Pending DC Count": st.column_config.NumberColumn("Pending DC's", format="%d"),
            },
        )

    # ── Raw Shipment Detail (collapsible) ──────────────────────────────────────
    if not detail_df.empty:
        with st.expander("🔍  Raw Shipment-level Records (click to expand)", expanded=False):
            # Show relevant columns only
            show_cols = [
                "Zone Name", "Plant Name", "SENDING PLANT",
                "SHIPMENT", "DELIVERY", "DELIVERY STATUS",
                "SHIPMENT STATUS", "BILLING DATE",
                "ORDER NO", "VEHICLE NUMBER", "QUANTITY", "QTY UOM",
            ]
            show_cols = [c for c in show_cols if c in detail_df.columns]
            raw_display = (
                detail_df[show_cols]
                .sort_values(by=["Zone Name", "Plant Name", "SHIPMENT"])
                .reset_index(drop=True)
            )
            st.dataframe(raw_display, use_container_width=True, hide_index=True)

    # ── Download Button ────────────────────────────────────────────────────────
    st.markdown("---")
    dl_col, _ = st.columns([1, 4])
    with dl_col:
        xlsx_bytes = export_to_excel({
            "Zone Summary" : zone_summary,
            "Plant Summary": summary_df,
            "Raw Data"     : detail_df if not detail_df.empty else pd.DataFrame(),
        })
        st.download_button(
            label     = "⬇️  Download Report  (.xlsx)",
            data      = xlsx_bytes,
            file_name = f"PendingDC_Report_{datetime.now().strftime('%Y%m%d_%H%M')}.xlsx",
            mime      = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            key       = "dl_pending_dc",
        )


# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION ENTRY POINT
# ─────────────────────────────────────────────────────────────────────────────

def main() -> None:
    """
    Application bootstrap:
      1. Initialise session state.
      2. Inject CSS.
      3. Load master data (cached).
      4. Render sidebar (filters + upload).
      5. Resolve data source (upload > default path).
      6. Process exception parameters.
      7. Route to the correct page.
    """

    # ── Session-state defaults ────────────────────────────────────────────────
    if "page" not in st.session_state:
        st.session_state["page"] = "dashboard"

    inject_css()

    # ── Load Master Data ──────────────────────────────────────────────────────
    try:
        df_plant = load_plant_master()
    except FileNotFoundError:
        st.error(
            f"❌ PlantMaster.xlsx not found at:\n`{PLANT_MASTER_PATH}`\n\n"
            "Please ensure the MAster/ folder is present next to app.py."
        )
        st.stop()
    except Exception as exc:
        st.error(f"❌ Failed to load PlantMaster: {exc}")
        st.stop()

    try:
        _df_zone = load_zone_master()          # loaded but available for future use
    except Exception as exc:
        st.sidebar.warning(f"⚠️ Zone master not loaded: {exc}")

    # ── Sidebar ───────────────────────────────────────────────────────────────
    selected_zones, selected_plants, uploaded_dc = render_sidebar(df_plant)

    # ── Resolve Pending DC Source ─────────────────────────────────────────────
    if uploaded_dc is not None:
        dc_source = uploaded_dc                        # user-uploaded file
    elif os.path.exists(PENDING_DC_PATH):
        dc_source = PENDING_DC_PATH                    # default file on disk
    else:
        dc_source = None

    # ── Load & Process Pending DC ─────────────────────────────────────────────
    if dc_source is not None:
        with st.spinner("Loading Pending DC data …"):
            df_dc = load_pending_dc(dc_source)
        pending_dc_result = process_pending_dc(
            df_dc,
            df_plant,
            zone_filter  = selected_zones  or None,
            plant_filter = selected_plants or None,
        )
    else:
        pending_dc_result = {
            "total_count" : 0,
            "summary_df"  : pd.DataFrame(),
            "zone_summary": pd.DataFrame(),
            "detail_df"   : pd.DataFrame(),
            "unmatched"   : [],
        }
        st.sidebar.warning("⚠️ No Pending DC file found. Upload via the sidebar.")

    # ── Page Router ───────────────────────────────────────────────────────────
    page = st.session_state.get("page", "dashboard")

    if page == "dashboard":
        render_dashboard(pending_dc_result, selected_zones, selected_plants)

    elif page == "pending_dc_details":
        render_pending_dc_details(pending_dc_result, selected_zones, selected_plants)

    else:
        # Fallback – reset to dashboard
        st.session_state["page"] = "dashboard"
        st.rerun()


# ─────────────────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    main()
